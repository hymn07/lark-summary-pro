datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client"
  output     = "./generated"
  engineType = "client"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "./zod"
  config   = "./zod-generator.config.json"
}

model User {
  id                 String          @id @default(cuid())
  name               String
  email              String
  emailVerified      Boolean
  image              String?
  createdAt          DateTime
  updatedAt          DateTime
  username           String?
  role               String?
  banned             Boolean?
  banReason          String?
  banExpires         DateTime?
  onboardingComplete Boolean         @default(false)
  paymentsCustomerId String?
  locale             String?
  displayUsername     String?
  twoFactorEnabled   Boolean?
  isAdmin            Boolean         @default(false)
  sessions           Session[]
  accounts           Account[]
  passkeys           Passkey[]
  invitations        Invitation[]
  purchases          Purchase[]
  members            Member[]
  twofactors         TwoFactor[]
  promptVersions     PromptVersion[]
  meetingRecords     MeetingRecord[]
  userModelAccesses  UserModelAccess[]
  createdProviders   ModelProvider[]
  createdMeetings   FeishuMeeting[]
  userSettings       UserSettings?
  sampleLearnings    SampleLearning[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  activeOrganizationId String?

  token     String
  createdAt DateTime
  updatedAt DateTime

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id           String    @id @default(cuid())
  accountId    String
  providerId   String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String?   @db.Text
  refreshToken String?   @db.Text
  idToken      String?   @db.Text
  expiresAt    DateTime?
  password     String?

  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String   @db.Text
  expiresAt  DateTime

  createdAt DateTime?
  updatedAt DateTime?

  @@index([identifier])
  @@map("verification")
}

model Passkey {
  id           String    @id @default(cuid())
  name         String?
  publicKey    String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  aaguid       String?
  createdAt    DateTime?

  @@index([userId])
  @@index([credentialID])
  @@map("passkey")
}

model TwoFactor {
  id          String @id @default(cuid())
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

model Organization {
  id                  String            @id @default(cuid())
  name                String
  slug                String?
  logo                String?
  createdAt           DateTime
  metadata            String?
  paymentsCustomerId  String?
  inboundEmailAddress String?           @unique
  inboundEmailShortId String?           @unique
  members             Member[]
  invitations         Invitation[]
  purchases           Purchase[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  createdAt      DateTime

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

enum PurchaseType {
  SUBSCRIPTION
  ONE_TIME
}

model Purchase {
  id             String        @id @default(cuid())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String?
  type           PurchaseType
  customerId     String
  subscriptionId String?       @unique
  productId      String
  status         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([subscriptionId])
  @@map("purchase")
}

enum MeetingRecordStatus {
  processing
  completed
  skipped
  failed
}

model PromptVersion {
  id               String            @id @default(cuid())
  name             String
  corePrompt       String            @db.Text
  styleDescription String?
  isDefault        Boolean           @default(false)
  isActive         Boolean           @default(false)
  createdById      String
  createdBy        User              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  meetingRecords   MeetingRecord[]
  userSettings     UserSettings[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([createdById])
  @@map("prompt_version")
}

model MeetingRecord {
  id               String              @id @default(cuid())
  meetingId        String
  feishuMeeting    FeishuMeeting?     @relation(fields: [meetingId], references: [meetingId])
  topic            String?
  startTime        DateTime?
  endTime          DateTime?
  hostUserId       String?
  participantCount Int?
  status           MeetingRecordStatus @default(processing)
  promptVersionId  String?
  promptVersion    PromptVersion?      @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)
  docUrl           String?
  docToken         String?
  skippedReason    String?
  aiSummary        String?             @db.Text
  errorMessage     String?             @db.Text
  userId           String
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  processingLogs   ProcessingLog[]
  isDeleted         Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([userId])
  @@index([status])
  @@index([startTime])
  @@index([userId, status])
  @@map("meeting_record")
}

model ModelProvider {
  id        String   @id @default(cuid())
  name      String
  apiBase   String
  apiKey    String
  models    Json     @default("[]")
  createdById String
  createdBy User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  userAccesses UserModelAccess[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("model_provider")
}

model UserModelAccess {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  modelProviderId String
  modelProvider   ModelProvider @relation(fields: [modelProviderId], references: [id], onDelete: Cascade)

  @@unique([userId, modelProviderId])
  @@index([userId])
  @@index([modelProviderId])
  @@map("user_model_access")
}

model UserSettings {
  id                    String         @id @default(cuid())
  userId                String         @unique
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  autoEnabled           Boolean        @default(true)
  saveFolderToken       String?
  extraInstructions     String?
  activePromptVersionId String?
  activePromptVersion   PromptVersion? @relation(fields: [activePromptVersionId], references: [id], onDelete: SetNull)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@map("user_settings")
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

model ProcessingLog {
  id              String        @id @default(cuid())
  meetingRecordId String
  meetingRecord   MeetingRecord @relation(fields: [meetingRecordId], references: [id], onDelete: Cascade)
  step            String
  status          String
  detail          String?       @db.Text
  createdAt       DateTime      @default(now())

  @@index([meetingRecordId])
  @@map("processing_log")
}

model SampleLearning {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  sampleDocTokens  Json     @default("[]")
  generatedPrompt  String   @db.Text
  styleDescription String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@map("sample_learning")
}

enum MeetingSource {
  feishu
  manual
}

model FeishuMeeting {
  id               String   @id @default(cuid())
  meetingId        String   @unique
  meetingNo        String?
  topic            String?
  startTime        DateTime?
  endTime          DateTime?
  hostUserId       String?
  participantCount Int?
  participantsJson Json?    @default("[]")
  transcriptText   String?  @db.Text
  transcriptFetched Boolean  @default(false)
  docUrl           String?
  source           MeetingSource @default(feishu)
  noteDocToken     String?
  meetingUrl       String?
  uploadedFileName String?
  createdById      String?
  createdBy        User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  isDeleted         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  meetingRecords   MeetingRecord[]

  @@index([startTime])
  @@index([meetingId])
  @@index([source])
  @@map("feishu_meeting")
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("waitlist_entry")
}